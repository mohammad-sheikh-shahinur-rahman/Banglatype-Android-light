<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@+id/setup_welcome_logo"
        android:layout_width="@dimen/setup_welcome_logo_size"
        android:layout_height="@dimen/setup_welcome_logo_size"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/setup_welcome_logo_top_margin"
        android:layout_marginBottom="@dimen/setup_welcome_logo_bottom_margin"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_banglatype" />
    <TextView
        android:id="@+id/setup_welcome_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/setup_welcome_title_top_margin"
        android:textColor="@color/bt_on_teal"
        android:textStyle="bold"
        android:gravity="center_horizontal"
        android:includeFontPadding="false"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="18sp"
        app:autoSizeMaxTextSize="@dimen/setup_title_text_size"
        app:autoSizeStepGranularity="1sp"
        android:hyphenationFrequency="none"
        android:breakStrategy="balanced"
        android:maxLines="2"
        style="@style/setupTitleStyle" />
    <TextView
        android:id="@+id/setup_welcome_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/setup_welcome_additional_description"
        android:layout_marginTop="@dimen/setup_welcome_description_top_margin"
        android:textColor="#CCFFFFFF"
        android:gravity="center_horizontal"
        android:lineSpacingMultiplier="1.2"
        android:alpha="0.9"
        android:hyphenationFrequency="none"
        style="@style/setupWelcomeDescritpionStyle" />
</merge>
