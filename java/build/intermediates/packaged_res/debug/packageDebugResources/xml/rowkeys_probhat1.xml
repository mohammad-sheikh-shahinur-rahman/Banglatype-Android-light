<!-- Probhat (প্রভাত) keyboard - top row (q..p).
     keySpec = unshifted glyph, moreKeys = shifted glyph + Bengali/Latin digit. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- q: দ / ধ / ১ -->
    <Key
        latin:keySpec="&#x09A6;"
        latin:keyHintLabel="&#x09E7;"
        latin:moreKeys="&#x09A7;,&#x09E7;,1" />
    <!-- w: ূ / ঊ / ২ -->
    <Key
        latin:keySpec="&#x09C2;"
        latin:keyHintLabel="&#x09E8;"
        latin:moreKeys="&#x098A;,&#x09E8;,2" />
    <!-- e: ী / ঈ / ৩ -->
    <Key
        latin:keySpec="&#x09C0;"
        latin:keyHintLabel="&#x09E9;"
        latin:moreKeys="&#x0988;,&#x09E9;,3" />
    <!-- r: র / ড় / ৪ -->
    <Key
        latin:keySpec="&#x09B0;"
        latin:keyHintLabel="&#x09EA;"
        latin:moreKeys="&#x09DC;,&#x09EA;,4" />
    <!-- t: ট / ঠ / ৫ -->
    <Key
        latin:keySpec="&#x099F;"
        latin:keyHintLabel="&#x09EB;"
        latin:moreKeys="&#x09A0;,&#x09EB;,5" />
    <!-- y: এ / ঐ / ৬ -->
    <Key
        latin:keySpec="&#x098F;"
        latin:keyHintLabel="&#x09EC;"
        latin:moreKeys="&#x0990;,&#x09EC;,6" />
    <!-- u: ু / উ / ৭ -->
    <Key
        latin:keySpec="&#x09C1;"
        latin:keyHintLabel="&#x09ED;"
        latin:moreKeys="&#x0989;,&#x09ED;,7" />
    <!-- i: ি / ই / ৮ -->
    <Key
        latin:keySpec="&#x09BF;"
        latin:keyHintLabel="&#x09EE;"
        latin:moreKeys="&#x0987;,&#x09EE;,8" />
    <!-- o: ও / ঔ / ৯ -->
    <Key
        latin:keySpec="&#x0993;"
        latin:keyHintLabel="&#x09EF;"
        latin:moreKeys="&#x0994;,&#x09EF;,9" />
    <!-- p: প / ফ / ০ -->
    <Key
        latin:keySpec="&#x09AA;"
        latin:keyHintLabel="&#x09E6;"
        latin:moreKeys="&#x09AB;,&#x09E6;,0" />
</merge>
