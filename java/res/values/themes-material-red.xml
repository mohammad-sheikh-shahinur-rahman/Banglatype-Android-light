<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">
    <style name="KeyboardTheme.Material_Red" parent="KeyboardIcons.LXX_Light">
        <item name="inputViewStyle">@style/InputView.LXX</item>
        <item name="keyboardStyle">@style/Keyboard.Material_Red</item>
        <item name="keyboardViewStyle">@style/KeyboardView.Material_Red</item>
        <item name="mainKeyboardViewStyle">@style/MainKeyboardView.Material_Red</item>
        <item name="emojiPalettesViewStyle">@style/EmojiPalettesView.Material_Red</item>
        <item name="moreKeysKeyboardStyle">@style/MoreKeysKeyboard.Material_Red</item>
        <item name="moreKeysKeyboardViewStyle">@style/MoreKeysKeyboardView.Material_Red</item>
        <item name="moreKeysKeyboardViewForActionStyle">@style/MoreKeysKeyboardView.Material_Red.Action</item>
        <item name="suggestionStripViewStyle">@style/SuggestionStripView.Material_Red</item>
        <item name="suggestionWordStyle">@style/SuggestionWord.Material_Red</item>
    </style>
    <style name="Keyboard.Material_Red" parent="Keyboard">
        <item name="themeId">MaterialRed</item>
    </style>
    <style name="KeyboardView.Material_Red" parent="KeyboardView.LXX">
        <item name="android:background">#FFEBEE</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_lxx_light</item>
        <item name="functionalKeyBackground">@drawable/btn_keyboard_key_functional_lxx_light</item>
        <item name="spacebarBackground">@drawable/btn_keyboard_spacebar_lxx_light</item>
        <item name="keyTextColor">#D32F2F</item>
        <item name="keyTextInactivatedColor">#FFCDD2</item>
        <item name="functionalTextColor">#B71C1C</item>
        <item name="keyHintLetterColor">#E57373</item>
        <item name="keyHintLabelColor">#EF9A9A</item>
        <item name="keyShiftedLetterHintInactivatedColor">#FFCDD2</item>
        <item name="keyShiftedLetterHintActivatedColor">#D32F2F</item>
        <item name="keyPreviewTextColor">#D32F2F</item>
    </style>
    <style name="MainKeyboardView.Material_Red" parent="KeyboardView.Material_Red">
        <item name="moreKeysKeyboardForActionLayout">@layout/more_keys_keyboard_for_action_lxx</item>
        <item name="keyPreviewBackground">@drawable/keyboard_key_feedback_lxx_light</item>
        <item name="keyPreviewHeight">@dimen/config_key_preview_height_lxx</item>
        <item name="keyPreviewOffset">@dimen/config_key_preview_offset_lxx</item>
        <item name="keyPreviewShowUpAnimator">@anim/key_preview_show_up_lxx</item>
        <item name="keyPreviewDismissAnimator">@anim/key_preview_dismiss_lxx</item>
        <item name="gestureFloatingPreviewTextColor">#FFFFFF</item>
        <item name="gestureFloatingPreviewColor">#F44336</item>
        <item name="gestureTrailColor">#F44336</item>
        <item name="slidingKeyInputPreviewColor">#80F44336</item>
        <item name="languageOnSpacebarTextColor">#D32F2F</item>
        <item name="languageOnSpacebarTextShadowRadius">-1.0</item>
    </style>
    <style name="EmojiPalettesView.Material_Red" parent="MainKeyboardView.Material_Red">
        <item name="categoryIndicatorEnabled">false</item>
        <item name="categoryPageIndicatorColor">#D32F2F</item>
        <item name="categoryPageIndicatorBackground">#FFEBEE</item>
        <item name="iconEmojiRecentsTab">@drawable/ic_emoji_recents_lxx_light</item>
        <item name="iconEmojiCategory1Tab">@drawable/ic_emoji_people_lxx_light</item>
        <item name="iconEmojiCategory2Tab">@drawable/ic_emoji_objects_lxx_light</item>
        <item name="iconEmojiCategory3Tab">@drawable/ic_emoji_nature_lxx_light</item>
        <item name="iconEmojiCategory4Tab">@drawable/ic_emoji_places_lxx_light</item>
        <item name="iconEmojiCategory5Tab">@drawable/ic_emoji_symbols_lxx_light</item>
        <item name="iconEmojiCategory6Tab">@drawable/ic_emoji_emoticons_lxx_light</item>
        <item name="iconEmojiCategory7Tab">@drawable/ic_emoji_flag_lxx_light</item>
    </style>
    <style name="MoreKeysKeyboard.Material_Red" parent="Keyboard.Material_Red">
        <item name="keyboardTopPadding">0%p</item>
        <item name="keyboardBottomPadding">0%p</item>
        <item name="horizontalGap">0%p</item>
        <item name="touchPositionCorrectionData">@null</item>
    </style>
    <style name="MoreKeysKeyboardView.Material_Red" parent="KeyboardView.Material_Red">
        <item name="android:background">#FFEBEE</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_popup_lxx_light</item>
        <item name="divider">@drawable/more_keys_divider</item>
        <item name="keyTypeface">normal</item>
        <item name="verticalCorrection">@dimen/config_more_keys_keyboard_vertical_correction_holo</item>
    </style>
    <style name="MoreKeysKeyboardView.Material_Red.Action" parent="MoreKeysKeyboardView.Material_Red">
        <item name="android:background">@android:color/transparent</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_popup_action_lxx_light</item>
        <item name="divider">@null</item>
        <item name="keyLabelFlags">keepBackgroundAspectRatio</item>
    </style>
    <style name="SuggestionStripView.Material_Red" parent="KeyboardView.Material_Red">
        <item name="suggestionsCountInStrip">@integer/config_suggestions_count_in_strip</item>
        <item name="centerSuggestionPercentile">@fraction/config_center_suggestion_percentile</item>
        <item name="maxMoreSuggestionsRow">@integer/config_max_more_suggestions_row</item>
        <item name="minMoreSuggestionsWidth">@fraction/config_min_more_suggestions_width</item>
        <item name="android:background">#FFEBEE</item>
        <item name="android:src">@drawable/suggestions_strip_divider_lxx_light</item>
        <item name="suggestionStripOptions">autoCorrectBold|validTypedWordBold</item>
        <item name="colorValidTypedWord">#D32F2F</item>
        <item name="colorTypedWord">#D32F2F</item>
        <item name="colorAutoCorrect">#B71C1C</item>
        <item name="colorSuggested">#D32F2F</item>
        <item name="alphaObsoleted">70%</item>
    </style>
    <style name="SuggestionWord.Material_Red" parent="SuggestionWord">
        <item name="android:background">@drawable/btn_suggestion_lxx_light</item>
        <item name="android:textColor">#D32F2F</item>
    </style>
</resources>
